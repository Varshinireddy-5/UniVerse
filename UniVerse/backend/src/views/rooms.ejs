<!DOCTYPE html>
<html>
<%- include('partials/head', { title: 'Rooms' }) %>
<body class="min-h-screen bg-gradient-to-br from-sky-100 via-blue-50 to-cyan-100">
  <%- include('partials/nav') %>
  <main class="max-w-6xl mx-auto p-6 space-y-6">
    <div class="bg-white/90 rounded-2xl border border-cyan-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-cyan-200 flex items-center justify-between">
        <p class="text-cyan-700 text-xl font-semibold">Rooms</p>
        <form method="post" action="/admin/rooms/create" class="flex items-center gap-2">
          <input name="name" placeholder="Name" class="px-3 py-2 rounded-xl bg-white border border-cyan-200 text-gray-800 placeholder-gray-400 focus:outline-none focus:border-cyan-400" required>
          <input name="rows" type="number" placeholder="Rows" class="px-3 py-2 rounded-xl bg-white border border-cyan-200 text-gray-800 placeholder-gray-400 focus:outline-none focus:border-cyan-400" required>
          <input name="cols" type="number" placeholder="Cols" class="px-3 py-2 rounded-xl bg-white border border-cyan-200 text-gray-800 placeholder-gray-400 focus:outline-none focus:border-cyan-400" required>
          <button class="px-4 py-2 rounded-xl bg-gradient-to-r from-sky-400 to-cyan-500 text-white">Create</button>
        </form>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-cyan-50 text-cyan-700">
            <tr>
              <th class="px-6 py-3 text-left">Name</th>
              <th class="px-6 py-3 text-left">Rows</th>
              <th class="px-6 py-3 text-left">Cols</th>
              <th class="px-6 py-3 text-left">Capacity</th>
              <th class="px-6 py-3 text-left">Seats</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-cyan-100 text-gray-700">
            <% for (const r of rooms) { %>
              <tr>
                <td class="px-6 py-3"><%= r.name %></td>
                <td class="px-6 py-3"><%= r.rows %></td>
                <td class="px-6 py-3"><%= r.cols %></td>
                <td class="px-6 py-3"><%= r.capacity %></td>
                <td class="px-6 py-3"><%= r._count && r._count.seats ? r._count.seats : 0 %></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
    <% if (message) { %>
      <div class="px-3 py-2 rounded-xl bg-green-500/20 text-green-700 border border-green-300"><%= message %></div>
    <% } %>
    <% if (error) { %>
      <div class="px-3 py-2 rounded-xl bg-red-500/20 text-red-700 border border-red-300"><%= error %></div>
    <% } %>
  </main>
</body>
</html>
